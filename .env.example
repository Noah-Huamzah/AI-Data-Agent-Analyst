# Copy to .env and fill in values

# Oracle DB
DB_USER=system
DB_PASSWORD=your_password_here
DB_DSN=localhost/FREEXDB

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
GENERATION_MODEL=qwen2.5-coder:3b
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=180
OLLAMA_FORCE_JSON=false

# Pipeline
MAX_ROWS=500              # hard DB cap per query
UI_MAX_ROWS=20            # rows returned in API/UI response
PIPELINE_TIMEOUT=60       # asyncio.wait_for cap in seconds
MAX_RETRIES=3
TOP_K_SCHEMA=7
CONFIDENCE_THRESH=0.5
CONVERSATION_TURNS=5

# Cache
CACHE_TTL_HOURS=24
# REDIS_URL=redis://localhost:6379
